<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Stegano.UI.Encoder">


            <DockPanel Margin="20">

                      <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,10">
                          <Button Content="Encoder" Click="OnEncodeClick" DockPanel.Dock="Right" Background="BlueViolet" Foreground="White" Padding="15,7"/>
                      </DockPanel>

                      <Grid ColumnDefinitions="*,*">

                          <StackPanel Grid.Column="0" Spacing="10" Margin="15,5">
                              <TextBlock Text="Données secrètes" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                              <TextBlock Text="Texte à cacher :" FontStyle="Italic"/>
                              <TextBox x:Name="EncodeDataBox" Watermark="Entrez le texte à cacher !" TextWrapping="Wrap" AcceptsReturn="True" Height="150" FontStyle="Italic"/>
                          </StackPanel>

                          <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5" CornerRadius="5">
                              <Panel>
                                  <TextBlock Text="Aucune image importée" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" IsVisible="{Binding !#EncodeImagePreview.Source}"/>
                                  <Image x:Name="EncodeImagePreview" Stretch="Uniform"/>
                              </Panel>
                          </Border>
                      </Grid>

            </DockPanel>
  
</UserControl>
