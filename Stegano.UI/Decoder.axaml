<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Stegano.UI.Decoder"
             x:Name="Root"
             xmlns:local="using:Stegano.UI.Converters">

    <UserControl.Resources>
        <local:NullToBoolConverter x:Key="NullToBoolConverter"/>
    </UserControl.Resources>

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10" Spacing="8">
            <DockPanel LastChildFill="False">
                <Button Content="Importer une image" Click="OnSelectImageClick" DockPanel.Dock="Left" Background="SlateBlue" Foreground="White" Padding="15,7"/>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="Décoder" Click="OnDecodeClick" Background="DodgerBlue" Foreground="White" Padding="15,7"/>
                    <Button Content="Copier le texte" Click="OnCopyTextClick" Background="DarkOrange" Foreground="White" Padding="15,7"/>
                </StackPanel>
            </DockPanel>

            <TextBlock Text="{Binding StatusMessage, ElementName=Root}"
                       Foreground="LightGray"
                       FontStyle="Italic"/>
            <ProgressBar IsIndeterminate="True"
                         Height="4"
                         IsVisible="{Binding IsLoading, ElementName=Root}"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Spacing="10" Margin="15,5">
                <TextBlock Text="Résultat du décodage" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding MessageUsageInfo, ElementName=Root}"
                           FontStyle="Italic"
                           Foreground="Gray"/>

                <TextBlock Text="Le message décodé apparaîtra ici après l'exécution." IsVisible="{Binding HasNoDecodedMessage, ElementName=Root}"/>

                <SelectableTextBlock x:Name="DecodeResultBox" TextWrapping="Wrap" FontSize="14"/>
            </StackPanel>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5" CornerRadius="5">
                <Panel>
                    <TextBlock Text="Aucune image importée"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" IsVisible="{Binding Source, ElementName=DecodeImagePreview, Converter={StaticResource NullToBoolConverter}}"/>
                    <Image x:Name="DecodeImagePreview" Stretch="Uniform"/>
                </Panel>
            </Border>
        </Grid>
    </DockPanel>

</UserControl>
